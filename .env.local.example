# Local-only env file. Mirrors Coolify magic vars so compose interpolates correctly.
# Copy to .env.local and edit. NEVER commit .env.local.

SERVICE_FQDN_COUCHDB_5984=http://localhost:5984
SERVICE_USER_COUCHDB=admin
SERVICE_PASSWORD_64_COUCHDB=changeme-local-only-at-least-rotate-before-prod

# Optional CouchDB tuning. Defaults match Coolify canonical template.
# MAX_DOCUMENT_SIZE=52428800       # 50 MB
# MAX_HTTP_REQUEST_SIZE=67108864   # 64 MB
