# Local-only env file. Mirrors Coolify magic vars so docker compose interpolates
# them locally. Copy to .env.local and edit. .env.local is gitignored.

SERVICE_USER_COUCHDB=admin
SERVICE_PASSWORD_64_COUCHDB=changeme-local-only-at-least-rotate-before-prod

# CouchDB sizes are baked into ./local.ini, not env. Edit local.ini to tune.
